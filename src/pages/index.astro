---
import Base           from "../layouts/Base.astro";
import Nav            from "../components/Nav.astro";
import Hero           from "../components/Hero.astro";
import SystemsSection from "../components/SystemsSection.astro";
import ResultsSection from "../components/ResultsSection.astro";
import WritingSamples from "../components/WritingSamples.astro";
import VideoSection   from "../components/VideoSection.astro";
import WhoIAm         from "../components/WhoIAm.astro";
import LogoStrip      from "../components/LogoStrip.astro";
import Footer         from "../components/Footer.astro";

import { config } from "../data/general";

const { meta, nav, hero } = config;
---

<Base
  title={meta.title}
  description={meta.description}
  noindex={meta.noindex}
>
  <Nav name={nav.name} links={[...nav.links]} />

  <main>
    <Hero
      eyebrow={hero.eyebrow}
      headline={hero.headline}
      tagline={hero.tagline}
    />
    <WhoIAm />
    <LogoStrip />
    <WritingSamples />
    <VideoSection />
    <SystemsSection />
    <ResultsSection />
  </main>

  <Footer />
</Base>
