---
// Logo strip — "Published & featured in"
// SVG wordmarks from Quietly design, rose color scheme
---

<div class="logo-strip">
  <p class="logo-strip-label">Published &amp; featured in</p>
  <div class="logo-track">

    <svg viewBox="0 0 180 36" xmlns="http://www.w3.org/2000/svg" aria-label="Douglas Magazine">
      <text x="0" y="26" font-family="Georgia, serif" font-size="22" font-weight="400" letter-spacing="1" fill="currentColor">Douglas</text>
      <text x="108" y="26" font-family="Georgia, serif" font-size="13" font-weight="400" letter-spacing="2" font-style="italic" fill="currentColor">magazine</text>
    </svg>

    <span class="logo-dot" aria-hidden="true"></span>

    <svg viewBox="0 0 120 36" xmlns="http://www.w3.org/2000/svg" aria-label="Databox">
      <rect x="0" y="8" width="6" height="20" rx="1" fill="currentColor"/>
      <rect x="9" y="14" width="6" height="14" rx="1" fill="currentColor"/>
      <rect x="18" y="4" width="6" height="24" rx="1" fill="currentColor"/>
      <text x="30" y="26" font-family="'DM Sans', Arial, sans-serif" font-size="18" font-weight="500" letter-spacing="0.5" fill="currentColor">databox</text>
    </svg>

    <span class="logo-dot" aria-hidden="true"></span>

    <svg viewBox="0 0 210 36" xmlns="http://www.w3.org/2000/svg" aria-label="Digital Entrepreneur">
      <text x="0" y="26" font-family="'DM Sans', Arial, sans-serif" font-size="15" font-weight="500" letter-spacing="1.5" fill="currentColor">DIGITAL ENTREPRENEUR</text>
    </svg>

    <span class="logo-dot" aria-hidden="true"></span>

    <svg viewBox="0 0 130 36" xmlns="http://www.w3.org/2000/svg" aria-label="iFundWomen">
      <text x="0" y="25" font-family="'DM Sans', Arial, sans-serif" font-size="17" font-weight="500" letter-spacing="0.5" fill="currentColor">iFundWomen</text>
    </svg>

    <span class="logo-dot" aria-hidden="true"></span>

    <svg viewBox="0 0 110 36" xmlns="http://www.w3.org/2000/svg" aria-label="Promo">
      <rect x="0" y="8" width="18" height="18" rx="3" fill="currentColor"/>
      <polygon points="5,12 5,24 15,18" fill="var(--rose-whisper)"/>
      <text x="24" y="25" font-family="'DM Sans', Arial, sans-serif" font-size="17" font-weight="600" letter-spacing="0.3" fill="currentColor">promo</text>
    </svg>

    <span class="logo-dot" aria-hidden="true"></span>

    <svg viewBox="0 0 148 36" xmlns="http://www.w3.org/2000/svg" aria-label="Content Marketing Institute">
      <text x="0" y="15" font-family="'DM Sans', Arial, sans-serif" font-size="9" font-weight="700" letter-spacing="1.8" fill="currentColor">CONTENT MARKETING</text>
      <text x="0" y="28" font-family="'DM Sans', Arial, sans-serif" font-size="9" font-weight="400" letter-spacing="2.2" fill="currentColor">INSTITUTE</text>
    </svg>

  </div>
</div>

<style>
.logo-strip {
  background: var(--rose-whisper);
  border-top: 1px solid rgba(181, 112, 106, 0.15);
  border-bottom: 1px solid rgba(181, 112, 106, 0.15);
  padding: 2rem var(--page-pad);
}

.logo-strip-label {
  font-size: 0.62rem;
  font-weight: 500;
  letter-spacing: 0.26em;
  text-transform: uppercase;
  color: var(--ink-muted);
  text-align: center;
  margin-bottom: 1.2rem;
}

.logo-track {
  display: flex;
  gap: 2rem;
  align-items: center;
  justify-content: center;
  flex-wrap: wrap;
}

.logo-track svg {
  height: 24px;
  width: auto;
  fill: var(--ink-soft);
  color: var(--ink-soft);
  opacity: 0.55;
  flex-shrink: 0;
  transition: opacity 0.2s, color 0.2s;
}

.logo-track svg:hover {
  opacity: 1;
  color: var(--rose-deep);
}

.logo-dot {
  display: block;
  width: 3px;
  height: 3px;
  border-radius: 50%;
  background: rgba(181, 112, 106, 0.35);
  flex-shrink: 0;
}

@media (max-width: 640px) {
  .logo-track { gap: 1.4rem; }
  .logo-track svg { height: 20px; }
  .logo-dot { display: none; }
}
</style>
