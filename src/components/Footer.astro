---
// Footer — dark background, name + LinkedIn
---

<footer>
  <div class="footer-inner">
    <span class="footer-name">Sharon Hadden Milone</span>

    <nav class="footer-nav" aria-label="Footer navigation">
      <a href="#systems">Systems</a>
      <a href="#results">Results</a>
      <a href="#writing">Writing</a>
      <a href="#watch">Watch</a>
      <a href="#about">About</a>
    </nav>

    <a
      href="https://www.linkedin.com/in/sharonmilone"
      target="_blank"
      rel="noopener"
      class="footer-linkedin"
      aria-label="Sharon Milone on LinkedIn"
    >
      <svg viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
      </svg>
      LinkedIn
    </a>
  </div>

  <div class="footer-bottom">
    <span class="footer-copy">
      © {new Date().getFullYear()} Sharon Hadden Milone · Content Systems Portfolio
    </span>
  </div>
</footer>

<style>
footer {
  background: var(--dark-bg);
  padding: 3.5rem var(--page-pad) 2rem;
  color: rgba(245, 237, 233, 0.55);
}

.footer-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: 1.5rem;
  padding-bottom: 2rem;
  border-bottom: 1px solid rgba(201, 144, 138, 0.15);
}

.footer-name {
  font-family: var(--serif);
  font-size: 1.05rem;
  font-weight: 400;
  color: rgba(245, 237, 233, 0.75);
  letter-spacing: 0.04em;
}

.footer-nav {
  display: flex;
  gap: 1.8rem;
  flex-wrap: wrap;
}

.footer-nav a {
  font-size: 0.67rem;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  color: rgba(245, 237, 233, 0.4);
  text-decoration: none;
  transition: color 0.2s;
}

.footer-nav a:hover {
  color: var(--rose-blush);
}

.footer-linkedin {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  font-size: 0.68rem;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--rose-mid);
  text-decoration: none;
  transition: color 0.2s;
}

.footer-linkedin:hover {
  color: var(--rose-blush);
}

.footer-linkedin svg {
  width: 16px;
  height: 16px;
}

.footer-bottom {
  padding-top: 1.4rem;
  text-align: center;
}

.footer-copy {
  font-size: 0.68rem;
  letter-spacing: 0.1em;
  color: rgba(245, 237, 233, 0.28);
}

@media (max-width: 640px) {
  .footer-inner { flex-direction: column; align-items: flex-start; }
  .footer-nav { gap: 1.2rem; }
}
</style>
