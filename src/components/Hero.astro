---
export interface Props {
  eyebrow: string;
  headline: string;
  tagline:  string;
}
const { eyebrow, headline, tagline } = Astro.props;
---

<header class="hero" id="top">
  <div class="hero-glow" aria-hidden="true"></div>

  <span class="hero-eyebrow">{eyebrow}</span>

  <h1>
    {headline}<br />
    <em>{tagline}</em>
  </h1>

  <div class="hero-rule" aria-hidden="true"></div>

  <div class="hero-ctas">
    <a href="#results" class="btn btn-primary">Results &amp; Impact</a>
    <a href="#systems" class="btn btn-secondary">Content Systems</a>
  </div>
</header>

<style>
.hero {
  background: var(--dark-bg);
  padding: 120px var(--page-pad) 100px;
  text-align: center;
  position: relative;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* Radial glow behind text */
.hero-glow {
  position: absolute;
  top: -80px; left: 50%;
  transform: translateX(-50%);
  width: 800px; height: 500px;
  background: radial-gradient(
    ellipse,
    rgba(181, 112, 106, 0.16) 0%,
    transparent 65%
  );
  pointer-events: none;
}

/* Eyebrow */
.hero-eyebrow {
  display: block;
  font-size: 0.68rem;
  font-weight: 500;
  letter-spacing: 0.3em;
  text-transform: uppercase;
  color: var(--rose-mid);
  margin-bottom: 1.6rem;
  opacity: 0;
  animation: fadeUp 0.7s ease 0.15s forwards;
}

/* Headline */
h1 {
  font-family: var(--serif);
  font-size: clamp(2.4rem, 5.5vw, 4.2rem);
  font-weight: 300;
  color: #f5ede9;
  line-height: 1.18;
  max-width: 820px;
  opacity: 0;
  animation: fadeUp 0.7s ease 0.3s forwards;
}

h1 em {
  font-style: italic;
  color: var(--rose-blush);
  display: block;
}

/* Decorative rule */
.hero-rule {
  width: 40px;
  height: 1px;
  background: var(--rose-deep);
  margin: 2rem auto 0;
  opacity: 0;
  animation: fadeUp 0.7s ease 0.45s forwards;
}

/* CTAs */
.hero-ctas {
  display: flex;
  gap: 1rem;
  flex-wrap: wrap;
  justify-content: center;
  margin-top: 2.4rem;
  opacity: 0;
  animation: fadeUp 0.7s ease 0.6s forwards;
}

/* Override global .btn colours for dark-bg context */
.btn-primary {
  background: var(--rose-deep);
  color: var(--warm-white);
  font-size: 0.72rem;
  font-weight: 500;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  text-decoration: none;
  padding: 0.9rem 2rem;
  transition: background 0.22s, transform 0.22s;
}
.btn-primary:hover { background: var(--rose-mid); transform: translateY(-1px); }

.btn-secondary {
  border: 1px solid rgba(232, 196, 188, 0.4);
  color: rgba(245, 230, 226, 0.75);
  font-size: 0.72rem;
  font-weight: 400;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  text-decoration: none;
  padding: 0.9rem 2rem;
  transition: border-color 0.22s, color 0.22s;
}
.btn-secondary:hover {
  border-color: var(--rose-blush);
  color: var(--rose-blush);
}

@media (max-width: 640px) {
  .hero { padding: 100px var(--page-pad) 80px; }
  h1 em { display: inline; }
}
</style>
