---
// Who I Am — two-column layout, photo left, content right
// Photo: public/images/sharon.jpg (extract from Quietly HTML if not yet done)
---

<section id="about">
  <div class="who-grid">

    <!-- Photo column -->
    <div class="who-photo-col reveal">
      <div class="who-photo-wrap">
        <img
          src="/portfolio/images/sharon.jpg"
          alt="Sharon Hadden Milone"
          class="who-photo"
          loading="lazy"
          decoding="async"
        />
      </div>
    </div>

    <!-- Content column -->
    <div class="who-content reveal delay-1">
      <span class="section-label">Who I Am</span>

      <h2 class="who-title">
        Content strategist.<br />
        <em>Systems thinker.</em>
      </h2>

      <div class="who-body">
        <p>
          I build content programs that scale — with or without AI. My work sits at
          the intersection of editorial strategy, systems design and emerging
          technology, and I bring the same rigour to a 50-word social caption as to
          a full-stack content operations architecture.
        </p>
        <p>
          Over the last decade I've led content at fintech companies, AI data
          platforms and independent publications — writing for audiences from
          small-business owners to enterprise buyers to the general public. I've
          also held editorial leadership roles, including Editor in Chief of
          Digital Entrepreneur.
        </p>
        <p>
          I'm currently deepening my practice in AI-native content systems:
          building pipelines that combine Claude, Supabase, and human editorial
          judgment into something more durable than either alone.
        </p>
      </div>

      <ul class="who-bullets">
        <li><span class="bullet-label">Based in</span> Victoria, BC · open to remote</li>
        <li><span class="bullet-label">Background</span> Journalism, digital marketing, editorial ops</li>
        <li><span class="bullet-label">Currently</span> Building AI-native content systems</li>
        <li><span class="bullet-label">Connect</span>
          <a href="https://www.linkedin.com/in/sharonmilone" target="_blank" rel="noopener">LinkedIn →</a>
        </li>
      </ul>
    </div>

  </div>
</section>

<style>
section {
  background: var(--warm-white);
}

.who-grid {
  display: grid;
  grid-template-columns: 340px 1fr;
  gap: 5rem;
  align-items: start;
}

/* Photo */
.who-photo-wrap {
  position: sticky;
  top: calc(var(--nav-h) + 2rem);
  border: 1px solid var(--border);
  overflow: hidden;
}

.who-photo {
  width: 100%;
  height: auto;
  display: block;
  aspect-ratio: 3 / 4;
  object-fit: cover;
  object-position: center top;
  filter: grayscale(18%);
  transition: filter 0.4s;
}

.who-photo-wrap:hover .who-photo {
  filter: grayscale(0%);
}

/* Content */
.who-title {
  font-family: var(--serif);
  font-size: clamp(1.9rem, 3.5vw, 2.8rem);
  font-weight: 300;
  color: var(--ink);
  line-height: 1.2;
  margin-top: 1.2rem;
  margin-bottom: 1.8rem;
}

.who-title em {
  font-style: italic;
  color: var(--rose-deep);
}

.who-body {
  max-width: 560px;
  margin-bottom: 2.4rem;
}

.who-body p {
  font-size: 0.93rem;
  color: var(--ink-soft);
  line-height: 1.88;
  font-weight: 300;
}

.who-body p + p {
  margin-top: 1rem;
}

/* Bullets */
.who-bullets {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: 0.7rem;
  border-top: 1px solid var(--border);
  padding-top: 1.6rem;
}

.who-bullets li {
  font-size: 0.85rem;
  color: var(--ink-soft);
  line-height: 1.5;
}

.bullet-label {
  display: inline-block;
  font-size: 0.62rem;
  font-weight: 500;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  color: var(--ink-muted);
  min-width: 110px;
  margin-right: 0.4rem;
}

.who-bullets a {
  color: var(--rose-deep);
  text-decoration: none;
  border-bottom: 1px solid rgba(181, 112, 106, 0.3);
  padding-bottom: 0.1rem;
  transition: color 0.2s, border-color 0.2s;
}

.who-bullets a:hover {
  color: var(--rose-mid);
  border-color: var(--rose-mid);
}

/* Responsive */
@media (max-width: 900px) {
  .who-grid {
    grid-template-columns: 1fr;
    gap: 2.5rem;
  }

  .who-photo-wrap {
    position: static;
    max-width: 280px;
  }
}

@media (max-width: 640px) {
  .who-photo-wrap { max-width: 100%; }
}
</style>
