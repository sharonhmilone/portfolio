---
// Writing samples — articles (linked) + multimedia (linked)
// Sama case study gets the full-width dark feature treatment at the top.

const articles = [
  {
    pub:   "Douglas Magazine",
    title: "Creating Content: Five Steps for an Intentional Online Content Strategy",
    url:   "https://www.douglasmagazine.com/creating-content-five-steps-for-an-intentional-online-content-strategy/",
  },
  {
    pub:   "Digital Entrepreneur",
    title: "I Woke Up a B Corp and Other World-Changing Views",
    url:   "https://www.digitalentrepreneur.com/explore/i-woke-up-a-b-corp-and-other-world-changing-views",
  },
  {
    pub:   "Digital Entrepreneur",
    title: "What's the Big Idea? London Tech Week 2025",
    url:   "https://www.digitalentrepreneur.com/explore/whats-the-big-idea-london-tech-week-2025",
  },
  {
    pub:   "iFundWomen",
    title: "Social Media for Your Crowdfunding Campaign",
    url:   "https://www.ifundwomen.com/social-media-for-your-crowdfunding",
  },
];

const multimedia = [
  {
    type:  "Interview · Digital Entrepreneur",
    title: "Changing the Way We Learn with Christopher Pommerening",
    desc:  "A conversation with the Co-Founder of LearnLife on purpose-inspired learning. Conducted and published as Editor in Chief of Digital Entrepreneur.",
    url:   "https://www.digitalentrepreneur.com/explore/changing-the-way-we-learn-with-christopher-pommerening",
    cta:   "Read Interview →",
  },
  {
    type:  "Video · Digital Entrepreneur",
    title: "Creative Routes: Unlock Creativity Through Unlearning",
    desc:  "Directed and oversaw production of this video — the first in Digital Entrepreneur's video series. The host was a local high school student passionate about the arts, a deliberate editorial choice.",
    url:   "https://youtu.be/KL1cqQyU0pI",
    cta:   "Watch Video →",
  },
  {
    type:  "Explainer · Samasource (Sama)",
    title: "8 Answers to Your Questions About AI and Machine Learning",
    desc:  "An accessible explainer on AI and ML written for a non-technical audience, part of Samasource's content program to build brand authority in the data labelling space.",
    url:   "https://www.sama.com/blog/8-answers-to-your-questions-about-ai-and-machine-learning",
    cta:   "Read Article →",
  },
];
---

<section id="writing">

  <!-- ── SAMA CASE STUDY FEATURE ── -->
  <div class="cs-feature reveal">
    <div class="cs-body">
      <span class="cs-eyebrow">Featured Case Study · Samasource (Sama)</span>
      <h3 class="cs-title">
        How Vulcan Is Using <em>AI for Wildlife Conservation</em>
      </h3>
      <div class="cs-text">
        <p>Written for Samasource's content program, this case study tells the story of Vulcan's use of AI-powered image recognition to support wildlife conservation across Africa. The piece translates complex machine learning applications for a general business audience, connecting technical capability to real-world impact.</p>
        <p>The work required deep collaboration with technical stakeholders to get the science right without losing the story. The result earned broad distribution and contributed to Samasource's recognition at the 2020 AI Breakthrough Awards.</p>
      </div>
      <a
        href="https://www.sama.com/blog/how-vulcan-is-using-ai-for-wildlife-conservation"
        target="_blank"
        rel="noopener"
        class="cs-link"
      >
        Read the case study →
      </a>
    </div>
    <div class="cs-award-panel">
      <span class="award-pill">Award Winner</span>
      <p class="award-title">"2020 AI Breakthrough Award"</p>
      <span class="award-body">Artificial Intelligence<br/>Breakthrough Awards</span>
    </div>
  </div>

  <!-- ── PUBLISHED ARTICLES ── -->
  <div class="sub-section reveal">
    <span class="section-label">Published Articles</span>
    <div class="article-grid">
      {articles.map((a) => (
        <a href={a.url} target="_blank" rel="noopener" class="article-card">
          <span class="article-pub">{a.pub}</span>
          <p class="article-title">{a.title}</p>
          <span class="article-cta">Read Article →</span>
        </a>
      ))}
    </div>
  </div>

  <!-- ── MULTIMEDIA ── -->
  <div class="sub-section reveal">
    <span class="section-label">Multimedia</span>
    <div class="media-grid">
      {multimedia.map((m) => (
        <a href={m.url} target="_blank" rel="noopener" class="media-card">
          <span class="media-type">{m.type}</span>
          <p class="media-title">{m.title}</p>
          <p class="media-desc">{m.desc}</p>
          <span class="media-cta">{m.cta}</span>
        </a>
      ))}
    </div>
  </div>

</section>

<style>
section {
  background: var(--warm-white);
}

/* ── Case Study Feature ── */
.cs-feature {
  display: grid;
  grid-template-columns: 1fr auto;
  gap: 3.5rem;
  align-items: start;
  background: var(--dark-bg);
  padding: 3.5rem;
  margin-bottom: 4rem;
  border-radius: 4px;
}

.cs-eyebrow {
  display: block;
  font-size: 0.62rem;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: var(--rose-mid);
  margin-bottom: 1rem;
}

.cs-title {
  font-family: var(--serif);
  font-size: clamp(1.7rem, 3vw, 2.4rem);
  font-weight: 300;
  line-height: 1.2;
  color: #f5ede9;
  margin-bottom: 1.4rem;
}
.cs-title em { font-style: italic; color: var(--rose-blush); }

.cs-text {
  font-size: 0.9rem;
  line-height: 1.88;
  color: rgba(245, 237, 233, 0.72);
  max-width: 580px;
  font-weight: 300;
}
.cs-text p + p { margin-top: 0.9rem; }

.cs-link {
  display: inline-block;
  margin-top: 1.6rem;
  font-size: 0.7rem;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--rose-mid);
  text-decoration: none;
  border-bottom: 1px solid rgba(201, 144, 138, 0.35);
  padding-bottom: 0.18rem;
  transition: color 0.2s, border-color 0.2s;
}
.cs-link:hover { color: var(--rose-blush); border-color: var(--rose-blush); }

/* Award panel */
.cs-award-panel {
  border: 1px solid rgba(201, 144, 138, 0.22);
  background: rgba(181, 112, 106, 0.1);
  padding: 2rem 1.8rem;
  text-align: center;
  min-width: 190px;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.8rem;
  align-self: start;
}

.award-pill {
  font-size: 0.58rem;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--rose-mid);
  border: 1px solid rgba(201, 144, 138, 0.35);
  padding: 0.3rem 0.8rem;
}

.award-title {
  font-family: var(--serif);
  font-size: 1.35rem;
  font-style: italic;
  font-weight: 300;
  color: #f5ede9;
  line-height: 1.3;
}

.award-body {
  font-size: 0.65rem;
  color: rgba(245, 237, 233, 0.4);
  line-height: 1.6;
  letter-spacing: 0.06em;
}

/* ── Shared sub-section ── */
.sub-section { margin-bottom: 3.5rem; }
.sub-section .section-label { margin-bottom: 1.4rem; }

/* ── Article grid ── */
.article-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 1.5rem;
}

.article-card {
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
  padding: 1.8rem 2rem;
  background: var(--cream);
  text-decoration: none;
  border-top: 2px solid var(--border);
  transition: border-color 0.22s, transform 0.22s;
}
.article-card:hover {
  border-color: var(--rose-deep);
  transform: translateY(-2px);
}

.article-pub {
  font-size: 0.62rem;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--ink-muted);
}

.article-title {
  font-family: var(--serif);
  font-size: 1.2rem;
  font-weight: 400;
  color: var(--ink);
  line-height: 1.35;
  flex: 1;
}

.article-cta {
  margin-top: 0.6rem;
  font-size: 0.68rem;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--rose-deep);
}

/* ── Multimedia grid ── */
.media-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1.5rem;
}

.media-card {
  display: flex;
  flex-direction: column;
  gap: 0.6rem;
  padding: 2rem 1.8rem;
  background: var(--cream);
  text-decoration: none;
  border: 1px solid var(--border);
  transition: background 0.22s, border-color 0.22s, transform 0.22s;
}
.media-card:hover {
  background: var(--rose-whisper);
  border-color: var(--rose-blush);
  transform: translateY(-2px);
}

.media-type {
  font-size: 0.6rem;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--ink-muted);
}

.media-title {
  font-family: var(--serif);
  font-size: 1.15rem;
  font-weight: 400;
  color: var(--ink);
  line-height: 1.3;
}

.media-desc {
  font-size: 0.84rem;
  color: var(--ink-soft);
  line-height: 1.72;
  font-weight: 300;
  flex: 1;
}

.media-cta {
  margin-top: 0.4rem;
  font-size: 0.68rem;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--rose-deep);
}

/* Responsive */
@media (max-width: 900px) {
  .cs-feature     { grid-template-columns: 1fr; }
  .cs-award-panel { min-width: unset; flex-direction: row; flex-wrap: wrap; justify-content: center; }
  .media-grid     { grid-template-columns: 1fr 1fr; }
}

@media (max-width: 640px) {
  .article-grid { grid-template-columns: 1fr; }
  .media-grid   { grid-template-columns: 1fr; }
  .cs-feature   { padding: 2rem 1.4rem; }
}
</style>
