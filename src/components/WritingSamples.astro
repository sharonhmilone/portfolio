---
// Writing & Work — articles + multimedia + video, all in one section
// Video content folded in below the writing cards

const pieces = [
  {
    eyebrow: "Article · Douglas Magazine",
    title:   "Creating Content: Five Steps for an Intentional Online Content Strategy",
    desc:    "A practical guide to building a content strategy with intention, written for a general business audience.",
    url:     "https://www.douglasmagazine.com/creating-content-five-steps-for-an-intentional-online-content-strategy/",
    cta:     "Read Article →",
  },
  {
    eyebrow: "Interview · Samasource (Sama)",
    title:   "8 Answers to Your Questions About AI and Machine Learning",
    desc:    "An accessible primer on AI and ML for a non-technical business audience, part of Samasource's content program to build authority in the data labelling space.",
    url:     "https://www.sama.com/blog/8-answers-to-your-questions-about-ai-and-machine-learning",
    cta:     "Listen Now →",
  },
  {
    eyebrow: "Interview · Digital Entrepreneur",
    title:   "Changing the Way We Learn with Christopher Pommerening",
    desc:    "A conversation with the Co-Founder of LearnLife on purpose-inspired learning. Conducted and published as Editor in Chief of Digital Entrepreneur.",
    url:     "https://www.digitalentrepreneur.com/explore/changing-the-way-we-learn-with-christopher-pommerening",
    cta:     "Listen Now →",
  },
];
---

<section id="writing">

  <span class="section-label reveal">Writing &amp; Work</span>
  <h2 class="section-title reveal">Work that has <em>earned its place</em></h2>
  <p class="writing-intro reveal">
    Published across B2B, fintech, AI and general interest titles. Everything
    written, edited or directed with a clear editorial purpose.
  </p>

  <div class="pieces-grid">
    {pieces.map((p, i) => (
      <a
        href={p.url}
        target="_blank"
        rel="noopener"
        class={`piece-card reveal${i === 1 ? " delay-1" : i === 2 ? " delay-2" : ""}`}
      >
        <span class="piece-eyebrow">{p.eyebrow}</span>
        <p class="piece-title">{p.title}</p>
        <p class="piece-desc">{p.desc}</p>
        <span class="piece-cta">{p.cta}</span>
      </a>
    ))}
  </div>

  <!-- ── VIDEO ── anchor kept for nav -->
  <div class="video-block" id="watch">

    <aside class="maiden-note reveal">
      <p>
        Much of my published writing and early career work appears under my maiden
        name <strong>Sharon L. Hadden</strong>. A Google search of that name surfaces
        many of my articles from Douglas Magazine, Databox and other outlets. The
        full depth of the written record that doesn't show up under Milone.
      </p>
    </aside>

    <div class="video-grid">
      {[
        { id: "-HS3C9Kptm0", title: "Shift Browser Tips to Master Your Productivity",          url: "https://youtu.be/-HS3C9Kptm0" },
        { id: "dys2E5z-j9o", title: "Watch This Before Accepting Your Browser Cookies",         url: "https://youtu.be/dys2E5z-j9o" },
        { id: "wWYbEZHIZuk", title: "Digital Burnout? How to Keep Your Sanity in an Online World", url: "https://youtu.be/wWYbEZHIZuk" },
      ].map((v, i) => (
        <a
          href={v.url}
          target="_blank"
          rel="noopener"
          class={`video-card reveal${i === 1 ? " delay-1" : i === 2 ? " delay-2" : ""}`}
        >
          <div class="thumb-wrap">
            <img
              src={`https://img.youtube.com/vi/${v.id}/maxresdefault.jpg`}
              alt={v.title}
              loading="lazy"
              decoding="async"
            />
            <div class="play-btn" aria-hidden="true">
              <svg viewBox="0 0 44 44" fill="none" xmlns="http://www.w3.org/2000/svg">
                <circle cx="22" cy="22" r="21" stroke="white" stroke-opacity="0.85" stroke-width="1.5"/>
                <polygon points="18,14 32,22 18,30" fill="white" fill-opacity="0.92"/>
              </svg>
            </div>
          </div>
          <div class="video-meta">
            <span class="video-label">Shift Tips · YouTube</span>
            <p class="video-title">{v.title}</p>
            <span class="video-cta">Watch →</span>
          </div>
        </a>
      ))}
    </div>

  </div>

</section>

<style>
section {
  background: var(--warm-white);
}

.writing-intro {
  font-size: 0.93rem;
  color: var(--ink-soft);
  line-height: 1.85;
  max-width: 520px;
  font-weight: 300;
  margin-bottom: 3rem;
}

/* Uniform 3-column grid */
.pieces-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1.5rem;
}

.piece-card {
  display: flex;
  flex-direction: column;
  gap: 0.7rem;
  padding: 2.2rem 2rem;
  background: var(--cream);
  border: 1px solid var(--border);
  text-decoration: none;
  border-top: 2px solid transparent;
  transition: border-color 0.22s, background 0.22s, transform 0.22s;
}

.piece-card:hover {
  border-top-color: var(--rose-deep);
  background: var(--rose-whisper);
  transform: translateY(-3px);
}

.piece-eyebrow {
  font-size: 0.6rem;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--ink-muted);
}

.piece-title {
  font-family: var(--serif);
  font-size: 1.15rem;
  font-weight: 400;
  color: var(--ink);
  line-height: 1.35;
  flex: 1;
}

.piece-desc {
  font-size: 0.84rem;
  color: var(--ink-soft);
  line-height: 1.72;
  font-weight: 300;
}

.piece-cta {
  margin-top: 0.4rem;
  font-size: 0.65rem;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--rose-deep);
}

/* ── Video block ── */
.video-block {
  margin-top: 3.5rem;
  padding-top: 3rem;
}

.maiden-note {
  background: var(--rose-whisper);
  border-left: 3px solid var(--rose-blush);
  padding: 1.1rem 1.5rem;
  margin-bottom: 2.5rem;
}

.maiden-note p {
  font-size: 0.87rem;
  color: var(--ink-soft);
  line-height: 1.8;
  font-weight: 300;
}

.maiden-note strong {
  color: var(--ink);
  font-weight: 500;
}

.video-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1.5rem;
}

.video-card {
  display: flex;
  flex-direction: column;
  text-decoration: none;
  background: var(--cream);
  border: 1px solid var(--border);
  overflow: hidden;
  transition: transform 0.22s, border-color 0.22s, box-shadow 0.22s;
}

.video-card:hover {
  transform: translateY(-3px);
  border-color: var(--rose-blush);
  box-shadow: 0 8px 28px rgba(181, 112, 106, 0.12);
}

.thumb-wrap {
  position: relative;
  aspect-ratio: 16 / 9;
  overflow: hidden;
  background: var(--dark-bg);
}

.thumb-wrap img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  transition: transform 0.4s ease, opacity 0.3s ease;
  opacity: 0.92;
}

.video-card:hover .thumb-wrap img {
  transform: scale(1.03);
  opacity: 1;
}

.play-btn {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(30, 22, 20, 0.28);
  transition: background 0.22s;
}

.video-card:hover .play-btn {
  background: rgba(30, 22, 20, 0.42);
}

.play-btn svg {
  width: 44px;
  height: 44px;
  filter: drop-shadow(0 2px 8px rgba(0,0,0,0.4));
  transition: transform 0.22s;
}

.video-card:hover .play-btn svg {
  transform: scale(1.1);
}

.video-meta {
  padding: 1.2rem 1.4rem 1.4rem;
  display: flex;
  flex-direction: column;
  gap: 0.35rem;
  flex: 1;
}

.video-label {
  font-size: 0.6rem;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--ink-muted);
}

.video-title {
  font-family: var(--serif);
  font-size: 1.05rem;
  font-weight: 400;
  color: var(--ink);
  line-height: 1.35;
  flex: 1;
}

.video-cta {
  margin-top: 0.4rem;
  font-size: 0.65rem;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--rose-deep);
}

/* Responsive */
@media (max-width: 860px) {
  .pieces-grid { grid-template-columns: 1fr 1fr; }
  .video-grid  { grid-template-columns: 1fr 1fr; }
}

@media (max-width: 520px) {
  .pieces-grid { grid-template-columns: 1fr; }
  .video-grid  { grid-template-columns: 1fr; }
}
</style>
